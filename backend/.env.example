NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=streamvault
DB_USER=root
DB_PASSWORD=root

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=1d
# JWT_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=change-this-refresh-secret-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# Stripe (optional — leave blank to disable payments)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel

# Bunny Stream (optional — leave blank to disable video upload)
BUNNY_STORAGE_ZONE=stream-ott-videos
BUNNY_API_KEY=51a28160-b7f9-4094-a0aeacdc43b6-6781-4c1d
BUNNY_LIBRARY_ID=674709
BUNNY_HOSTNAME=vz-8fee5f3f-6e6.b-cdn.net
# BunnyCDN Pull Zone Token Authentication key (from CDN → Security → Token Authentication)
# When set, all CDN stream URLs are signed with a 4-hour expiry token
BUNNY_TOKEN_KEY=87908b39-82c8-4eae-b732-5dd8b36e5f28
# Email (optional — leave blank to disable transactional email)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=StreamVault <noreply@streamvault.com>

# Frontend origin (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# Affiliate program
# Commission rate paid to referrer on referred user's first payment (0.10 = 10%)
AFFILIATE_COMMISSION_RATE=0.10

# § 2257 Compliance — custodian of records
COMPLIANCE_CUSTODIAN_NAME=StreamVault Records Manager
COMPLIANCE_CUSTODIAN_ADDRESS=123 Streaming Lane, Mumbai, Maharashtra 400001, India
COMPLIANCE_CUSTODIAN_EMAIL=compliance@streamvault.com
COMPLIANCE_CUSTODIAN_PHONE=+91-XXXXXXXXXX

# File uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=524288000
