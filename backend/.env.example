NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=streamvault
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=change-this-refresh-secret-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# Stripe (optional — leave blank to disable payments)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel

# Bunny Stream (optional — leave blank to disable video upload)
BUNNY_STORAGE_ZONE=
BUNNY_API_KEY=
BUNNY_LIBRARY_ID=
BUNNY_HOSTNAME=

# Email (optional — leave blank to disable transactional email)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=StreamVault <noreply@streamvault.com>

# Frontend origin (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# File uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=524288000
